{
  "name": "cortex-plugin-reconciliation",
  "version": "1.0.1",
  "description": "Automated Reconciliation Engine \u2014 Match transactions across bank feeds, payment processors, and accounting systems",
  "kind": "esm",
  "entryPoint": "mod.ts",
  "runtime": "deno",
  "author": "CortexPrism",
  "license": "MIT",
  "repository": "https://github.com/CortexPrism/cortex-plugin-reconciliation",
  "homepage": "https://cortexprism.io/marketplace/plugins/reconciliation",
  "capabilities": [
    "tools",
    "network:fetch"
  ],
